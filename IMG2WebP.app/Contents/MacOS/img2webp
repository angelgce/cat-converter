    def filesUpdated_(self, files):
        count = len(files)
        self.fileCountLabel.setStringValue_(f"FILES ({count})")
        self.emptyLabel.setHidden_(count > 0)

        # Rebuild list
        for sv in list(self.fileContainer.subviews()):
            sv.removeFromSuperview()

        rowH = 22
        cW = self.fileContainer.frame().size.width
        totalH = max(rowH * count, self.fileScrollView.frame().size.height - 8)
        self.fileContainer.setFrameSize_((cW, totalH))

        for i, f in enumerate(files):
            name = os.path.basename(str(f))
            ry = totalH - (i + 1) * rowH
            row = NSView.alloc().initWithFrame_(NSMakeRect(0, ry, cW, rowH))

            isSelected = (i == self._selectedIndex)

            if isSelected:
                row.setWantsLayer_(True)
                row.layer().setBackgroundColor_(C_ACCENT_DIM.CGColor())
                row.layer().setCornerRadius_(4)
            elif i % 2 == 0:
                row.setWantsLayer_(True)
                row.layer().setBackgroundColor_(C_ROW_ALT.CGColor())
                row.layer().setCornerRadius_(4)

            dot = NSView.alloc().initWithFrame_(NSMakeRect(8, (rowH - 5) / 2, 5, 5))
            dot.setWantsLayer_(True)
            dotColor = C_ACCENT if isSelected else C_ACCENT
            dot.layer().setBackgroundColor_(dotColor.CGColor())
            dot.layer().setCornerRadius_(2.5)
            row.addSubview_(dot)

            nameLabel = label(NSMakeRect(20, 1, cW - 28, rowH - 2), name,
                              NSFont.monospacedSystemFontOfSize_weight_(10.5, 0), C_WHITE)
            row.addSubview_(nameLabel)
            self.fileContainer.addSubview_(row)

        self.statusLabel.setStringValue_(f"{count} file{'s' if count != 1 else ''} queued")
        self.statusLabel.setTextColor_(C_ACCENT)

        # Update preview
        if count > 0:
            self._selectedIndex = max(0, min(self._selectedIndex, count - 1))
            self._updatePreview()
        else:
            self._updatePreview()

    @objc.python_method
    def _isVideoFile(self, path):
        return os.path.splitext(str(path))[1].lower() in VIDEO_EXT

    @objc.python_method
    def _updatePreview(self):
        files = self.dropZone.files
        count = len(files) if files else 0
        if count == 0:
            self.previewImageView.setImage_(None)
            self.previewLabel.setStringValue_("PREVIEW")
            self.flipBtn.setEnabled_(True)
            self.removeBgBtn.setEnabled_(HAS_VISION)
            return
        idx = max(0, min(self._selectedIndex, count - 1))
        self._selectedIndex = idx
        path = str(files[idx])
        is_video = self._isVideoFile(path)
        if is_video:
            image = None
            kind = "VIDEO"
        else:
            image = NSImage.alloc().initWithContentsOfFile_(path)
            kind = "IMAGE"
        self.previewImageView.setImage_(image)
        self.previewLabel.setStringValue_(f"PREVIEW ({idx + 1}/{count}) - {kind}")
        self.flipBtn.setEnabled_(not is_video)
        self.removeBgBtn.setEnabled_((not is_video) and HAS_VISION)

    @objc.typedSelector(b'v@:@')
    def prevClicked_(self, sender):

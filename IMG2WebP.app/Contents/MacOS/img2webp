    @objc.typedSelector(b'v@:@')
    def flipClicked_(self, sender):
        files = self.dropZone.files
        if not files or len(files) == 0:
            self.writeLog("No file selected to flip.", C_RED)
            return

        path = str(files[self._selectedIndex])
        bn = os.path.basename(path)
        if self._isVideoFile(path):
            self.writeLog(f"Flip is only available for images: {bn}", C_RED)
            return

        try:
            image = NSImage.alloc().initWithContentsOfFile_(path)
            if not image:
                self.writeLog(f"Cannot load: {bn}", C_RED)
                return

            size = image.size()
            newImage = NSImage.alloc().initWithSize_(size)
            newImage.lockFocus()

            transform = NSAffineTransform.transform()
            transform.translateXBy_yBy_(size.width, 0)
            transform.scaleXBy_yBy_(-1.0, 1.0)
            transform.concat()

            image.drawAtPoint_fromRect_operation_fraction_(
                (0, 0),
                NSMakeRect(0, 0, size.width, size.height),
                NSCompositingOperationSourceOver,
                1.0
            )

            newImage.unlockFocus()

            # Save as PNG
            tiffData = newImage.TIFFRepresentation()
            bitmapRep = NSBitmapImageRep.imageRepWithData_(tiffData)
            pngData = bitmapRep.representationUsingType_properties_(4, {})  # 4 = NSBitmapImageFileTypePNG

            base, ext = os.path.splitext(path)
            outPath = base + "_flipped.png"
            pngData.writeToFile_atomically_(outPath, True)

            # Replace in file list
            idx = self._selectedIndex
            files.replaceObjectAtIndex_withObject_(idx, outPath)
            self.filesUpdated_(files)
            self.writeLog(f"Flipped: {os.path.basename(outPath)}", C_GREEN)

        except Exception as e:
            self.writeLog(f"Flip error: {e}", C_RED)

    @objc.typedSelector(b'v@:@')
    def removeBgClicked_(self, sender):
        files = self.dropZone.files
        if not files or len(files) == 0:
            self.writeLog("No file selected.", C_RED)
            return
        if not HAS_VISION:
            self.writeLog("Vision framework not available.", C_RED)
            return

        path = str(files[self._selectedIndex])
        bn = os.path.basename(path)
        if self._isVideoFile(path):
            self.writeLog(f"BG removal is only available for images: {bn}", C_RED)
            return
        self.writeLog(f"Removing background: {bn}...", C_CYAN)

        try:
            url = NSURL.fileURLWithPath_(path)
            ciImg = CIImage.imageWithContentsOfURL_(url)
            if ciImg is None:
                self.writeLog(f"Cannot load image: {bn}", C_RED)
                return

            handler = VNImageRequestHandler.alloc().initWithCIImage_options_(ciImg, None)
            request = VNGenerateForegroundInstanceMaskRequest.alloc().init()

            success, error = handler.performRequests_error_([request], None)
            if not success:
                errMsg = str(error) if error else "unknown error"
                self.writeLog(f"BG removal failed: {errMsg}", C_RED)
                return

            results = request.results()
            if not results or len(results) == 0:
                self.writeLog(f"No subject detected in: {bn}", C_RED)
                return

            observation = results[0]
            allInstances = observation.allInstances()

            maskedImage, error = observation.generateMaskedImageOfInstances_from_croppedToInstancesExtent_error_(
                allInstances, handler, False, None)

            if maskedImage is None:
                errMsg = str(error) if error else "unknown error"
                self.writeLog(f"BG removal failed: {errMsg}", C_RED)
                return

            # Save as PNG with transparency via NSCIImageRep
            base, ext = os.path.splitext(path)
            outPath = base + "_nobg.png"

            rep = NSCIImageRep.imageRepWithCIImage_(maskedImage)
            nsImg = NSImage.alloc().initWithSize_(rep.size())
            nsImg.addRepresentation_(rep)

            # Render to bitmap to get proper PNG with alpha
            imgSize = nsImg.size()
            bitmapRep = NSBitmapImageRep.alloc().initWithBitmapDataPlanes_pixelsWide_pixelsHigh_bitsPerSample_samplesPerPixel_hasAlpha_isPlanar_colorSpaceName_bytesPerRow_bitsPerPixel_(
                None, int(imgSize.width), int(imgSize.height),
                8, 4, True, False, "NSCalibratedRGBColorSpace", 0, 0)
            NSGraphicsContext = objc.lookUpClass('NSGraphicsContext')
            ctx = NSGraphicsContext.graphicsContextWithBitmapImageRep_(bitmapRep)
            NSGraphicsContext.setCurrentContext_(ctx)
            nsImg.drawAtPoint_fromRect_operation_fraction_(
                (0, 0), NSMakeRect(0, 0, imgSize.width, imgSize.height),
                NSCompositingOperationSourceOver, 1.0)
            ctx.flushGraphics()

            pngData = bitmapRep.representationUsingType_properties_(4, {})  # 4 = PNG
            pngData.writeToFile_atomically_(outPath, True)

            if os.path.exists(outPath):
                # Replace in file list
                idx = self._selectedIndex
                files.replaceObjectAtIndex_withObject_(idx, outPath)
                self.filesUpdated_(files)
                self.writeLog(f"BG removed: {os.path.basename(outPath)}", C_GREEN)
            else:
                self.writeLog(f"BG removal: failed to save output", C_RED)

        except Exception as e:
            self.writeLog(f"BG removal error: {e}", C_RED)

    @objc.python_method
    def writeLog(self, msg, color=None):
        if color is None:
            color = C_GRAY
        storage = self.logView.textStorage()
        attrs = NSDictionary.dictionaryWithObjects_forKeys_(
            [NSFont.monospacedSystemFontOfSize_weight_(11, 0), color],
            [NSFontAttributeName, NSForegroundColorAttributeName]
        )
        s = NSAttributedString.alloc().initWithString_attributes_(msg + "\n", attrs)
        storage.appendAttributedString_(s)
        self.logView.scrollRangeToVisible_((storage.length(), 0))

    @objc.python_method
    def _outputPath(self, fp, out_ext):
        base = os.path.splitext(fp)[0]
        out = base + out_ext
        if os.path.abspath(out) == os.path.abspath(fp):
            out = base + "_converted" + out_ext
        return out

    @objc.python_method
    def _missingTool(self, tool_path):
        return not tool_path or not os.path.exists(tool_path)

    @objc.python_method
    def _sizeChangeText(self, orig, new):
        if orig <= 0:
            return "0%"
        delta = orig - new
        pct = abs((delta * 100) // orig)
        return f"-{pct}%" if delta >= 0 else f"+{pct}%"

    @objc.python_method
    def _totalChangeText(self, total_saved):
        mb = abs(total_saved) / (1024 * 1024)
        return f"{mb:.1f} MB saved" if total_saved >= 0 else f"{mb:.1f} MB larger"

    @objc.typedSelector(b'v@:@')
    def convertClicked_(self, sender):
        files = self.dropZone.files
        if not files or len(files) == 0:
            self.writeLog("No files to convert.", C_RED)
            return

        n = len(files)
        self.writeLog(f"--- Converting {n} file{'s' if n != 1 else ''} ---", C_ACCENT)
        self.statusLabel.setStringValue_("Converting...")
        self.statusLabel.setTextColor_(C_CYAN)

        ok = 0
        fail = 0
        total_saved = 0

        for fp in list(files):
            fp = str(fp)
            bn = os.path.basename(fp)

            try:
                ext = os.path.splitext(fp)[1].lower()
                is_video = ext in VIDEO_EXT
                if is_video:
                    out = self._outputPath(fp, ".webm")
                    if self._missingTool(FFMPEG):
                        raise RuntimeError(f"ffmpeg not found at {FFMPEG}")
                    r = subprocess.run([
                        FFMPEG, '-y', '-i', fp,
                        '-c:v', 'libvpx-vp9', '-crf', '34', '-b:v', '0',
                        '-row-mt', '1',
                        '-c:a', 'libopus', '-b:a', '96k',
                        out
                    ], capture_output=True, text=True, timeout=600)
                else:
                    out = self._outputPath(fp, ".webp")
                    if ext in CWEBP_FORMATS and not self._missingTool(CWEBP):
                        r = subprocess.run([CWEBP, '-q', '80', fp, '-o', out],
                                           capture_output=True, text=True, timeout=60)
                    else:
                        if self._missingTool(FFMPEG):
                            raise RuntimeError(f"ffmpeg not found at {FFMPEG}")
                        r = subprocess.run([FFMPEG, '-y', '-i', fp, '-quality', '80', out],
                                           capture_output=True, text=True, timeout=60)

                if r.returncode == 0 and os.path.exists(out):
                    orig = os.path.getsize(fp)
                    new = os.path.getsize(out)
                    total_saved += orig - new
                    change = self._sizeChangeText(orig, new)
                    self.writeLog(f"  OK   {bn} -> {os.path.basename(out)}  {change}", C_GREEN)
                    ok += 1
                else:
                    err = (r.stderr or r.stdout or "").strip().splitlines()
                    detail = f": {err[-1]}" if err else ""
                    self.writeLog(f"  FAIL {bn}{detail}", C_RED)
                    fail += 1
            except Exception as e:
                self.writeLog(f"  FAIL {bn}: {e}", C_RED)
                fail += 1

        total_text = self._totalChangeText(total_saved)
        self.writeLog(f"Done: {ok} converted, {fail} failed, {total_text}", C_ACCENT)
        self.statusLabel.setStringValue_(f"Done - {total_text}")
        self.statusLabel.setTextColor_(C_GREEN)

    @objc.typedSelector(b'v@:@')
    def clearClicked_(self, sender):
        self.dropZone.files.removeAllObjects()
        self.dropZone.setNeedsDisplay_(True)
        self.fileCountLabel.setStringValue_("FILES")
        self.emptyLabel.setHidden_(False)
        for sv in list(self.fileContainer.subviews()):
            sv.removeFromSuperview()
        self.logView.setString_("")
        self.writeLog("IMG2WebP ready. Drop images or videos and click Convert.", C_GRAY)
        self.statusLabel.setStringValue_("Ready")
        self.statusLabel.setTextColor_(C_GRAY)
        self._selectedIndex = 0
        self.previewImageView.setImage_(None)
        self.previewLabel.setStringValue_("PREVIEW")
        self.flipBtn.setEnabled_(True)
        self.removeBgBtn.setEnabled_(HAS_VISION)

    def applicationShouldTerminateAfterLastWindowClosed_(self, app):
        return True



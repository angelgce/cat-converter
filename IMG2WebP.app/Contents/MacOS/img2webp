def label(frame, text, font, color, align=None):
    lbl = NSTextField.alloc().initWithFrame_(frame)
    lbl.setStringValue_(text)
    lbl.setBezeled_(False)
    lbl.setDrawsBackground_(False)
    lbl.setEditable_(False)
    lbl.setSelectable_(False)
    lbl.setFont_(font)
    lbl.setTextColor_(color)
    if align is not None:
        lbl.setAlignment_(align)
    return lbl


class DropZoneView(NSView):

    def initWithFrame_(self, frame):
        self = objc.super(DropZoneView, self).initWithFrame_(frame)
        if self is None:
            return None
        self.files = NSMutableArray.alloc().init()
        self.delegate = None
        self._hover = False
        self.registerForDraggedTypes_([NSFilenamesPboardType])
        return self

    def draggingEntered_(self, sender):
        pb = sender.draggingPasteboard()
        if NSFilenamesPboardType in pb.types():
            self._hover = True
            self.setNeedsDisplay_(True)
            return NSDragOperationCopy
        return 0

    def draggingExited_(self, sender):
        self._hover = False
        self.setNeedsDisplay_(True)

    def performDragOperation_(self, sender):
        self._hover = False
        pb = sender.draggingPasteboard()
        paths = pb.propertyListForType_(NSFilenamesPboardType)
        if paths:
            for p in paths:
                ext = os.path.splitext(str(p))[1].lower()
                if ext in VALID_EXT and p not in self.files:
                    self.files.addObject_(p)
            if self.delegate:
                self.delegate.filesUpdated_(self.files)
        self.setNeedsDisplay_(True)
        return True

    def drawRect_(self, rect):
        b = self.bounds()
        w, h = b.size.width, b.size.height

        # Fill
        bg = C_ACCENT_GLOW if self._hover else C_CARD
        bg.set()
        NSBezierPath.bezierPathWithRoundedRect_xRadius_yRadius_(b, 14, 14).fill()

        # Dashed border
        inR = NSMakeRect(2, 2, w - 4, h - 4)
        bp = NSBezierPath.bezierPathWithRoundedRect_xRadius_yRadius_(inR, 12, 12)
        bp.setLineDash_count_phase_([6.0, 4.0], 2, 0)
        bp.setLineWidth_(1.5)
        c = C_ACCENT if self._hover else C_ACCENT_DIM
        c.set()
        bp.stroke()

        count = len(self.files) if self.files else 0

        # Center icon
        icon = "+" if count == 0 else str(count)
        fsize = 42 if count == 0 else 36
        iAttrs = NSDictionary.dictionaryWithObjects_forKeys_(
            [NSFont.systemFontOfSize_weight_(fsize, 0.15),
             C_ACCENT if self._hover else C_WHITE50],
            [NSFontAttributeName, NSForegroundColorAttributeName]
        )
        iStr = NSAttributedString.alloc().initWithString_attributes_(icon, iAttrs)
        iSz = iStr.size()
        iStr.drawAtPoint_(((w - iSz.width) / 2, h / 2 + 4))

        # Label
        txt = "Drop images or videos here" if count == 0 else ("file" + ("s" if count != 1 else "") + " ready")
        tAttrs = NSDictionary.dictionaryWithObjects_forKeys_(
            [NSFont.systemFontOfSize_weight_(13, 0.2), C_WHITE50],
            [NSFontAttributeName, NSForegroundColorAttributeName]
        )
        tStr = NSAttributedString.alloc().initWithString_attributes_(txt, tAttrs)
        tSz = tStr.size()
        tStr.drawAtPoint_(((w - tSz.width) / 2, h / 2 - 26))

        # Formats
        sub = "PNG  JPG  HEIC  GIF  MP4  MOV  MKV" if count == 0 else "drop more or click Convert"
        sAttrs = NSDictionary.dictionaryWithObjects_forKeys_(
            [NSFont.systemFontOfSize_(10), C_GRAY],
            [NSFontAttributeName, NSForegroundColorAttributeName]
        )
        sStr = NSAttributedString.alloc().initWithString_attributes_(sub, sAttrs)
        sSz = sStr.size()
        sStr.drawAtPoint_(((w - sSz.width) / 2, h / 2 - 44))


